# =====================================================================
# THIS FILE IS COMMITTED TO GIT. NEVER PUT REAL SECRETS HERE.
# Copy it to ".env" (which is gitignored) and put real values there:
#     cp .env.example .env
# =====================================================================

ADGUARD_PASS=

# Custom dashboard login. Leave BLANK to keep the dashboard open (no login).
# Set any value to require this password at a JARVIS-themed login screen.
DASHBOARD_PASSWORD=

# Optional: pin the session-signing secret so logins survive even a full
# data wipe. If unset, one is generated and saved under ./data automatically.
SESSION_SECRET=
